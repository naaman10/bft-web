# Contentful (optional — site uses defaults if unset)
CONTENTFUL_SPACE_ID=h9pen7p8e4c2
CONTENTFUL_ACCESS_TOKEN=oaDlkDS18Yo7kUbnicokzw6hNZGmidWKJU_FgYGqxEcyour_delivery_api_token
# Optional: omit to use the space default locale (recommended if reviews look empty with en-US).
# CONTENTFUL_LOCALE=en-GB
# If the Review content type API ID is not "review", set it here.
# CONTENTFUL_REVIEW_CONTENT_TYPE=Reviews
# Verbose Contentful review logs on the server (1 = on). In development, review debug
# logs also run without this (see [contentful:reviews] / [homepage] in the terminal).
# CONTENTFUL_DEBUG=1

# Contact form — optional email delivery via Resend (https://resend.com)
# If unset, submissions still succeed and are logged on the server (e.g. Vercel logs).
RESEND_API_KEY=
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=

# Neon Postgres — contact form rows are inserted into the "lead" table (see sql/lead.sql).
# Copy the pooled or direct connection string from the Neon dashboard.
DATABASE_URL=
# If your table is not named "lead" (e.g. "leads"), set the identifier here (letters, numbers, underscore only).
# LEAD_TABLE_NAME=lead
# Optional: value stored in lead.source (default is "website").
# LEAD_SOURCE=website
# Add to JSON error responses: Postgres message/code (production debugging).
# CONTACT_DEBUG=1

# Public site URL (canonical origin for JSON-LD, optional metadata). No trailing slash.
# NEXT_PUBLIC_SITE_URL=https://www.example.com

# Termly Consent Management — website UUID from the Termly dashboard (optional; layout has a fallback).
# NEXT_PUBLIC_TERMLY_WEBSITE_UUID=0a6a6e27-c09c-41a7-82db-79117b51814c

# Feature flags — `NEXT_PUBLIC_*` is inlined at build time; redeploy after changing.
# Subject pages (`/subjects/*`) and Subjects nav: default on. Use false or 0 to disable.

# Contact form — bot protection (Cloudflare Turnstile)
# Create a widget at https://dash.cloudflare.com/?to=/:account/turnstile
# Use the same site for local dev (localhost) and production hostnames.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
